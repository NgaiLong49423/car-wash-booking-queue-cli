@@ -0,0 +1,125 @@
+package datastructure;
+
+import model.Booking;
+
+public class BookingBSTree {
+    private BookingTreeNode root;
+
+    public BookingBSTree() {
+        root = null;
+    }
+
+    public void clear() {
+        root = null;
+    }
+
+    public void insert(Booking x) {
+        if (x == null || x.getBookingId() == null) {
+            return;
+        }
+
+        if (root == null) {
+            root = new BookingTreeNode(x);
+            return;
+        }
+
+        BookingTreeNode p = root;
+        BookingTreeNode f = null;
+        String newId = x.getBookingId();
+
+        while (p != null) {
+            if (p.info.getBookingId().equalsIgnoreCase(newId)) {
+                p.info = x;
+                return;
+            }
+
+            f = p;
+            if (newId.compareToIgnoreCase(p.info.getBookingId()) < 0) {
+                p = p.left;
+            } else {
+                p = p.right;
+            }
+        }
+
+        if (newId.compareToIgnoreCase(f.info.getBookingId()) < 0) {
+            f.left = new BookingTreeNode(x);
+        } else {
+            f.right = new BookingTreeNode(x);
+        }
+    }
+
+    public Booking search(String bookingId) {
+        if (bookingId == null || bookingId.trim().isEmpty()) {
+            return null;
+        }
+
+        BookingTreeNode p = root;
+        String searchId = bookingId.trim();
+
+        while (p != null) {
+            if (p.info.getBookingId().equalsIgnoreCase(searchId)) {
+                return p.info;
+            }
+
+            if (searchId.compareToIgnoreCase(p.info.getBookingId()) < 0) {
+                p = p.left;
+            } else {
+                p = p.right;
+            }
+        }
+
+        return null;
+    }
+
+    public void delete(String bookingId) {
+        if (bookingId == null || bookingId.trim().isEmpty()) {
+            return;
+        }
+
+        BookingTreeNode p = root;
+        BookingTreeNode f = null;
+        String deleteId = bookingId.trim();
+
+        while (p != null && !p.info.getBookingId().equalsIgnoreCase(deleteId)) {
+            f = p;
+            if (deleteId.compareToIgnoreCase(p.info.getBookingId()) < 0) {
+                p = p.left;
+            } else {
+                p = p.right;
+            }
+        }
+
+        if (p == null) {
+            return;
+        }
+
+        if (p.left != null && p.right != null) {
+            BookingTreeNode rp = p.left;
+            BookingTreeNode frp = p;
+
+            while (rp.right != null) {
+                frp = rp;
+                rp = rp.right;
+            }
+
+            p.info = rp.info;
+            p = rp;
+            f = frp;
+        }
+
+        BookingTreeNode child;
+        if (p.left != null) {
+            child = p.left;
+        } else {
+            child = p.right;
+        }
+
+        if (f == null) {
+            root = child;
+        } else if (f.left == p) {
+            f.left = child;
+        } else {
+            f.right = child;
+        }
+    }
+}
