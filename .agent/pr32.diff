+
+        while (p != null && !p.info.getId().equalsIgnoreCase(deleteId)) {
+            f = p;
+            if (deleteId.compareToIgnoreCase(p.info.getId()) < 0) {
+                p = p.left;
+            } else {
+                p = p.right;
+            }
+        }
+
+        if (p == null) {
+            return;
